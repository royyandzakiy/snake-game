# =============================================================================
# clangd + CMake C++ template — focused ignore list
# =============================================================================

# ----- Build output -----
build/
cmake-build-*/        # CLion default build dirs
bin/
out/
Testing/

# CMake scratch (when configuring outside build/)
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
install_manifest.txt
*-prefix/
_deps/

# ----- clangd / compile database -----
# Mirrored to the project root by CMake; machine- and preset-specific.
compile_commands.json
.cache/               # clangd background index

# ----- Generated sources -----
# Produced at configure time by cmake/version.cmake from version.h.in
include/*/version.h
# (mylib_export.h is generated into the build tree, not here — see src/mylib/CMakeLists.txt)

# ----- Library install staging -----
# Auto-populated by MyLib's POST_BUILD `cmake --install` into the repo root.
generated_lib/

# ----- Package managers / local config -----
vcpkg_installed/
CMakeUserPresets.json
project_options.local.cmake

# ----- Compiled artifacts -----
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out
*.app
*.pdb
*.ilk
*.exp
*.gch
*.pch

# ----- Coverage -----
*.gcda
*.gcno
*.profraw
*.profdata
coverage/

# ----- IDE / editor (kept project-agnostic) -----
# .vscode/ is committed (shared config); .idea/ is CLion-local.
.idea/
.vs/
*.user
.history/
*.code-workspace

# ----- Claude Code local settings -----
.claude/settings.local.json

# ----- OS junk -----
.DS_Store
Thumbs.db
desktop.ini

# ----- Editor swap/backup -----
*~
*.swp
