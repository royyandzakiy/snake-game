{
  // Build via the CMake Tools task provider, using the active preset.
  // Used as the preLaunchTask in launch.json so F5 always debugs a fresh build.
  "version": "2.0.0",
  "tasks": [
    {
      "type": "cmake",
      "label": "CMake: build",
      "command": "build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
